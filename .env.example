# ======================================================
# Vitamins HUB — Environment Variables Template
# نسخ هذا الملف إلى .env وملء القيم الفعلية
# ======================================================

# Backend API URL
BACKEND_URL=
NEXT_PUBLIC_API_URL=

# Site URL (مهم جداً للإنتاج)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

PORT=3000

# AI Provider Keys (لا تشارك هذه القيم أبداً)
APIFREE_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Tracking & Analytics Pixels
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_SNAPCHAT_PIXEL_ID=
